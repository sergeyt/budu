# --- Required ---

# Postgres connection string (Neon, Supabase, RDS, local Postgres, ...).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB?sslmode=require

# NextAuth (https://authjs.dev). AUTH_TRUST_HOST=true is needed when
# running behind a tunnel (ngrok, Cloudflare) or any reverse proxy.
AUTH_URL=http://localhost:3000
AUTH_SECRET=change_me_to_a_long_random_string
AUTH_TRUST_HOST=true

# --- OAuth providers (optional; configure at least one to allow sign-in) ---
# Each provider is loaded only if BOTH its id and secret are set.

# Yandex ID
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# VK ID
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Sber ID (OpenID Connect)
SBER_ISSUER=https://login.sber.ru/oidc/
SBER_CLIENT_ID=
SBER_CLIENT_SECRET=

# TBank/Tinkoff ID (OpenID Connect)
TBANK_ISSUER=https://id.tinkoff.ru/oidc/
TBANK_CLIENT_ID=
TBANK_CLIENT_SECRET=

# --- Notifications (optional) ---

# Telegram bot used for /api/webhook/telegram and to send event updates.
TELEGRAM_BOT_TOKEN=
# HMAC key used to sign one-time `/link <code>` codes for binding a chat
# to a place. Use a strong random string in production.
TELEGRAM_LINK_SECRET=
# Optional secret appended to the webhook URL to reject unsigned hits.
TELEGRAM_WEBHOOK_SECRET=

# Shared secret for `/api/internal/bot/*` — used by the Deno Telegram bot
# service. Generate a long random string; never expose to clients.
BOT_INTERNAL_TOKEN=

# MAX Messenger transport (placeholder API; adjust base URL to the real one).
MAX_API_URL=https://api.maxmessenger.example/bot
MAX_BOT_TOKEN=

# --- Observability (optional) ---

# Sentry DSN (server, edge, and client share this).
SENTRY_DSN=

# Number of automatic retries on transient Prisma errors (P1001/P1002/P2024,
# ECONNREFUSED, ETIMEDOUT). 0 disables retries.
DATABASE_RETRY=0
