generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  CONFIRMED
  RESERVED
}

enum UserRole {
  USER
  SUPERADMIN
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String?        @unique
  emailVerified     DateTime?
  image             String?
  rttfProfileUrl    String?
  role              UserRole       @default(USER)
  // Populated when the user registers via the Telegram bot (or links their
  // web account through the bot). Bot-only users have a User row with all
  // OAuth fields null and telegramUserId set.
  telegramUserId    BigInt?        @unique
  telegramUsername  String?
  telegramFirstName String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt
  accounts          Account[]
  sessions          Session[]
  registrations     Registration[]
  adminPlaces       PlaceAdmin[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Place {
  id          String                     @id @default(cuid())
  name        String                     @unique
  location    String?
  description String?
  infoUrl     String?
  // IANA timezone for the place's physical location (e.g. "Europe/Moscow",
  // "Asia/Tbilisi"). Event templates inherit this when materializing into
  // concrete UTC `Event.startAt` instants. Stored on Place (not template)
  // because a place has one location and thus one canonical zone.
  timezone    String                     @default("Europe/Moscow")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @default(now()) @updatedAt
  events      Event[]
  templates   EventTemplate[]
  admins      PlaceAdmin[]
  // default channels under for all events for this place
  channels    PlaceNotificationChannel[]
}

model PlaceAdmin {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model Event {
  id              String                     @id @default(cuid())
  title           String
  description     String?
  // it could be also used for RTTF tournaments
  infoUrl         String?
  startAt         DateTime
  // event length in minutes; nullable so callers can opt out
  durationMinutes Int?                       @default(60)
  placeId         String
  place           Place                      @relation(fields: [placeId], references: [id], onDelete: Cascade)
  // Set when an event was materialized from a recurring template.
  // SetNull (not Cascade) so deleting a template doesn't wipe history.
  templateId      String?
  template        EventTemplate?             @relation(fields: [templateId], references: [id], onDelete: SetNull)
  // Records every live announcement posted for this event so the bot can
  // edit the same message instead of reposting. Shape:
  //   [{ chatId: string, messageId: number, lastRenderedAt: string,
  //      lastSignature: string }]
  // chatId is stored as string to keep big chat ids out of JSON number land.
  announcements   Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @default(now()) @updatedAt
  capacity        Int?
  reserveCapacity Int?
  regs            Registration[]
  channels        EventNotificationChannel[] // overrides/additions specific to this event

  @@unique([templateId, startAt])
  @@index([placeId, startAt])
}

/// Weekly recurring "show" run by a place. A scheduler materializes one
/// `Event` row per occurrence ahead of time and the bot posts an
/// announcement to the configured channels at `startAt -
/// announceOffsetMinutes`.
///
/// Time is decomposed into (dayOfWeek, localTime, place.timezone). The
/// materializer converts that to a UTC `Event.startAt`; the timezone
/// lives on Place rather than here so all templates at one venue share
/// it and admins can't typo it per-template.
model EventTemplate {
  id                    String                             @id @default(cuid())
  placeId               String
  place                 Place                              @relation(fields: [placeId], references: [id], onDelete: Cascade)
  title                 String
  description           String?
  infoUrl               String?
  // ISO weekday: 1 = Monday … 7 = Sunday (matches Luxon's `weekday`).
  dayOfWeek             Int
  // Local time of day in `place.timezone`. Postgres TIME(0) rejects
  // invalid values at insert; Prisma surfaces it as a Date whose date
  // portion is the epoch — extract HH:MM:SS at the materializer.
  localTime             DateTime                           @db.Time(0)
  durationMinutes       Int?                               @default(60)
  capacity              Int?
  reserveCapacity       Int?
  // How many minutes before startAt to post the announcement.
  // Default 24h. 0 = post immediately on materialization.
  announceOffsetMinutes Int                                @default(1440)
  enabled               Boolean                            @default(true)
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @default(now()) @updatedAt
  events                Event[]
  // Per-template overrides; otherwise the bot falls back to the place's
  // channels via the same precedence rule used at event level.
  channels              EventTemplateNotificationChannel[]

  @@index([placeId, enabled])
}

model EventTemplateNotificationChannel {
  id         String                  @id @default(cuid())
  templateId String
  template   EventTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type       NotificationChannelType
  target     String
  meta       Json?
  label      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([templateId, type, target])
}

model Registration {
  id        String             @id @default(cuid())
  userId    String
  eventId   String
  status    RegistrationStatus @default(CONFIRMED)
  createdAt DateTime           @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, status, createdAt])
}

enum NotificationChannelType {
  TELEGRAM
  WHATSAPP
  SLACK
  MAX
  EMAIL
  WEBHOOK
}

model PlaceNotificationChannel {
  id      String                  @id @default(cuid())
  placeId String
  place   Place                   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type    NotificationChannelType
  // For TELEGRAM, store chat id as string; for WEBHOOK, store URL; for EMAIL, store address.
  target  String
  // optional metadata (JSON) if you need parse_mode, thread ids, etc.
  meta    Json?
  label   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([placeId, type, target]) // prevents duplicates in same scope
}

model EventNotificationChannel {
  id      String                  @id @default(cuid())
  eventId String
  event   Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type    NotificationChannelType
  target  String
  meta    Json?
  label   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([eventId, type, target])
}
