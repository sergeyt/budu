# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Next.js app URL — the bot talks to `/api/internal/bot/*` over HTTP.
API_BASE_URL=http://localhost:3000

# Shared secret for the internal bot API. MUST match BOT_INTERNAL_TOKEN
# in the Next app's .env.
BOT_INTERNAL_TOKEN=dev-only-internal-token-change-me

# HMAC secret used to sign one-time `/link <code>` codes that bind a
# Telegram chat to a Place. MUST match TELEGRAM_LINK_SECRET in the Next
# app so codes minted in the web UI verify here.
TELEGRAM_LINK_SECRET=dev-only-secret

# HMAC secret used to sign callback_data buttons under live announcement
# messages. Independent from the link secret because its rotation cadence
# is different.
TELEGRAM_CALLBACK_SECRET=dev-only-callback-secret

# Public URL for Mini App links in inline keyboards (defaults to API_BASE_URL).
WEB_APP_BASE_URL=http://localhost:3000

# Optional Sentry DSN for the Deno bot.
SENTRY_DSN=

# polling | webhook. Local dev: polling. Deno Deploy: webhook.
BOT_MODE=polling

# Webhook mode only: public URL where Telegram posts updates.
WEBHOOK_URL=
# Webhook mode only: random secret appended to the path so unauthenticated
# hits get rejected without ever invoking grammY.
WEBHOOK_SECRET=

# Webhook mode only: port to bind to. Deno Deploy injects PORT.
PORT=8080
