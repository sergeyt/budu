# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Next.js app URL — the bot talks to `/api/internal/bot/*` over HTTP.
API_BASE_URL=http://localhost:3000

# Shared secret for the internal bot API. MUST match BOT_INTERNAL_TOKEN
# in the Next app's .env. Also used to derive the Telegram webhook secret.
BOT_INTERNAL_TOKEN=dev-only-internal-token-change-me

# HMAC secret for `/link <code>` (must match TELEGRAM_LINK_SECRET in the Next
# app) and for inline-keyboard callback_data on announcements.
TELEGRAM_LINK_SECRET=dev-only-secret

# Public URL for Mini App links in inline keyboards (defaults to API_BASE_URL).
WEB_APP_BASE_URL=http://localhost:3000

# Optional Sentry DSN for the Deno bot.
SENTRY_DSN=

# Public HTTPS origin of this bot (Deno Deploy, ngrok, …). When set, the bot
# registers POST {origin}/webhook with Telegram on startup. Leave unset for
# long-polling (local dev).
# BOT_PUBLIC_URL=https://your-bot.deno.dev

# HTTP port when serving webhooks (Deno Deploy injects PORT).
PORT=8080
